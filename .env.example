# Copia este archivo a .env y ajusta los valores.

# Nombre del proyecto (se muestra en la documentacion de la API)
PROJECT_NAME="Complejidad App API"

# Origenes permitidos para CORS (separados por coma).
# Aqui debe ir la URL del frontend, p. ej. http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
